# CodeIgniter 4 .gitignore

# Environment files
.env
.env.prod
env
env.producao

# Temporary zip/archives
*.zip
*.tar.gz

# System files
.DS_Store
Thumbs.db

# Writable directory
writable/cache/*
writable/debugbar/*
writable/logs/*
writable/session/*
writable/uploads/*
!writable/index.html
!writable/.gitkeep
!writable/session/.gitkeep
!writable/cache/.gitkeep
!writable/debugbar/.gitkeep
!writable/logs/.gitkeep
!writable/uploads/.gitkeep

# Composer vendor
vendor/

# User uploads
public/uploads/

# User custom ignores
scratch/
.agents
skills-lock.json
.claude
CLAUDE.md